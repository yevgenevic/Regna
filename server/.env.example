# ──────────────────────────────────────────────────────────────
# RAGNA — Environment Configuration (SRS §3)
# ──────────────────────────────────────────────────────────────

# Infrastructure
DATABASE_URL="postgresql://ragna_admin:[PASSWORD]@db:5432/ragna_core"
PORT=4000

# AI Provider Priorities
TEXT_AI_PROVIDER="gemini,openrouter"
IMAGE_AI_PROVIDER="comet,vertex"

# API Keys
GEMINI_API_KEY="AIza..."
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
COMET_API_KEY="sk-..."
COMET_API_BASE_URL="https://api.cometapi.com/v1"

# Google Cloud (optional — leave empty for local storage)
GCS_BUCKET_NAME="ragna-manga-panels"
GCS_PROJECT_ID=""

# Server
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
